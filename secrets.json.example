 {
  "Admin:Email": "admin@localhost.local",
  "Admin:Password": "YOUR_SECRET_JWT_KEY_MINIMUM_32_CHARACTERS_LONG_FOR_SECURITY",
  "ConnectionStrings:DefaultConnection": "YOUR_SQL_PASSWORD",
  "Cors:AllowedOrigins": [ "http://localhost:3000", "http://localhost:5173", "https://localhost:3000", "https://localhost:5173" ],
  "Cors:AllowCredentials": true,
  "Cors:AllowedHeaders": ["Content-Type", "Authorization", "X-Requested-With"],
  "Cors:AllowedMethods": ["GET","POST","PUT","DELETE","OPTIONS","PATCH"],
  "Cors:ExposedHeaders": ["Content-Disposition"],
  "Cors:MaxAgeSeconds": 3600
  "Database:ApplyMigrationsOnStartup": false,
  "Database:SeedAdminOnStartup": false,
  "Database:SeedRolesOnStartup": false,
  "DisableHttpsRedirection": false,
  "JwtSettings:AccessTokenMinutes": "15",
  "JwtSettings:Audience": "https://acme.dev",
  "JwtSettings:Issuer": "https://acme.dev",
  "JwtSettings:Key": "YourSuperSe11etKeyThatIsAtLeast32CharactersLong1234567890",
  "JwtSettings:RefreshTokenDays": "7",
  "Logging:Seq:ApiKey": "123456789",
  "Logging:Seq:BatchPeriodSeconds": 2,
  "Logging:Seq:BufferPath": "logs/seq-buffer",
  "Logging:Seq:QueueSizeLimit": 100000,
  "Logging:Seq:ServerUrl": "http://localhost:5341"
  "OpenTelemetry:ExportTimeoutMilliseconds": 3000,
  "OpenTelemetry:MaxExportBatchSize": 512,
  "OpenTelemetry:MaxQueueSize": 2048,
  "OpenTelemetry:OtlpEndpoint": "http://localhost:4317",
  "OpenTelemetry:ServiceName": "Acme.Api",
  "OpenTelemetry:ServiceVersion": "0.1.0"
  }