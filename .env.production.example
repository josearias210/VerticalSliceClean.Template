# ============================================
# Production Environment Variables
# ============================================
# Copy this file to .env in production and fill with actual values
# NEVER commit .env to git!

# ============================================
# Docker Image
# ============================================
DOCKER_IMAGE=ghcr.io/josearias210/acme-api:latest

# ============================================
# Domain & Network
# ============================================
DOMAIN=api.yourdomain.com

# ============================================
# Database Configuration
# ============================================
DB_NAME=Acme
SQL_SA_PASSWORD=YourStrongPassword123!ChangeMe

# Database initialization (set to false after first run)
DB_APPLY_MIGRATIONS=true
DB_SEED_ROLES=true
DB_SEED_ADMIN=true

# ============================================
# JWT Configuration
# ============================================
# IMPORTANT: Generate a secure key with at least 32 characters
# Example: openssl rand -base64 32
JWT_SECRET_KEY=CHANGE_ME_TO_A_SECURE_RANDOM_KEY_MINIMUM_32_CHARACTERS
JWT_ISSUER=Acme.Acme.Api
JWT_AUDIENCE=Acme.Acme.Api
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# ============================================
# Admin User (Initial Setup)
# ============================================
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=SecureAdminPassword123!ChangeMe

# ============================================
# CORS Origins
# ============================================
CORS_ORIGIN_1=https://yourdomain.com
CORS_ORIGIN_2=https://www.yourdomain.com

# ============================================
# Logging
# ============================================
LOG_LEVEL=Information

# Seq (optional, leave empty to disable)
SEQ_URL=
SEQ_API_KEY=

# ============================================
# OpenTelemetry (optional, leave empty to disable)
# ============================================
OTEL_ENDPOINT=

# ============================================
# Application Version
# ============================================
APP_VERSION=1.0.0
