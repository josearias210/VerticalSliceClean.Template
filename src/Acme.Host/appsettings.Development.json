{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Acme": "Debug",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Database": {
    "ApplyMigrationsOnStartup": true,
    "SeedRolesOnStartup": true,
    "SeedAdminOnStartup": true
  }
}
