# =============================================================================
# Docker Compose - Desarrollo Local (docker-compose.local.yml)
# =============================================================================
# Copia este archivo a .env y ajusta los valores según sea necesario
# Comando: Copy-Item .env.example .env (PowerShell) o cp .env.example .env (Bash)
# ¡No subas secretos reales al control de versiones!

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_PORT=8080
API_METRICS_PORT=8081
JWT_SECRET_KEY=SuperSecretKeyForDevelopmentOnly1234567890
JWT_ISSUER=Acme
JWT_AUDIENCE=Acme.Api

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DB_NAME=AcmeDb

# -----------------------------------------------------------------------------
# Jaeger Configuration (Distributed Tracing)
# -----------------------------------------------------------------------------
JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318

# -----------------------------------------------------------------------------
# Seq Configuration (Structured Logging)
# -----------------------------------------------------------------------------
SEQ_UI_PORT=5341
SEQ_INGESTION_PORT=5342
SEQ_ADMIN_PASSWORD=Admin123!
SEQ_API_KEY=

# =============================================================================
# Acceso a Servicios
# =============================================================================
# API:         http://localhost:8080
# Swagger:     http://localhost:8080/swagger
# PostgreSQL:  localhost:5432 (user: postgres, pass: postgres)
# Jaeger UI:   http://localhost:16686
# Seq UI:      http://localhost:5341 (user: admin, password: Admin123!)